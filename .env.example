# ═══════════════════════════════════════════════
# ZENITH FX — Environment Variables
# Copy this to .env.local for local dev
# Add ALL of these in Vercel → Settings → Environment Variables
# ═══════════════════════════════════════════════

# ── YOUR SITE URL (no trailing slash) ──────────
# In Vercel this is auto-set, but also set it manually:
NEXT_PUBLIC_SITE_URL=https://zenithfx.vercel.app

# ── SUPABASE (free tier works — supabase.com) ──
# Used for: user accounts, balances, trades, KYC, transactions
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── LIPANA.DEV M-PESA ──────────────────────────
# Get from: https://lipana.dev → Dashboard → API Keys
LIPANA_SECRET_KEY=lip_sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret from Lipana dashboard → Webhooks → Secret
LIPANA_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── GOOGLE OAUTH ───────────────────────────────
# Get from: console.cloud.google.com → Credentials → OAuth 2.0
# Authorized redirect URI: https://xxxxxxxxxxxx.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=XXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXX

# ── EMAIL (SMTP) ───────────────────────────────
# Use Gmail App Password or any SMTP provider (Resend, Mailgun, etc.)
# Gmail: myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mwebidouglas08@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="Zenith FX <noreply@zenithfx.io>"

# ── CURRENCY RATE ──────────────────────────────
USD_KES_RATE=130

# ── ADMIN ──────────────────────────────────────
ADMIN_EMAIL=mwebidouglas08@gmail.com
